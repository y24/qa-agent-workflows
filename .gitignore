# Runtime outputs
outputs/runs/*
!outputs/runs/.gitkeep

# Shareable examples may be committed intentionally.
!outputs/examples/
!outputs/examples/**

# Working directory
work/*

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
!.pytest_cache/
.pytest_cache/*
!.pytest_cache/cache/
.pytest_cache/cache/*
!.pytest_cache/cache/.gitkeep
pytest-cache-files-*/
